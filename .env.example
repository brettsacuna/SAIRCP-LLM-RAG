# ============================================
# SAIRCP-LLM-RAG — Variables de Entorno
# ============================================
# Copiar a .env y completar valores reales.
# NUNCA commitear el archivo .env al repositorio.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- App ---
APP_NAME=SAIRCP-LLM-RAG
DEBUG=true
LOG_LEVEL=INFO

# --- RAG ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
SIMILARITY_THRESHOLD=0.75

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=saircp_documents

# --- PostgreSQL ---
DATABASE_URL=postgresql://saircp:saircp_pass@db:5432/saircp_db

# --- Seguridad ---
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Scoring ---
SCORE_THRESHOLD_LOW=30
SCORE_THRESHOLD_MEDIUM=60
